# ── Database ────────────────────────────────────────────────────────────────
MONGOURI=mongodb+srv://user:pass@cluster/db

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# ── AI engine ───────────────────────────────────────────────────────────────
# The slide-generation service (backend/ai-engine), exposes POST /jobs (SSE).
AI_ENGINE_URL=http://localhost:8080

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Email (Mailchimp Transactional / Mandrill API) ──────────────────────────
MAILCHIMP_TRANSACTIONAL_KEY=md-your-mandrill-api-key
MAILCHIMP_FROM_EMAIL=hello@yourdomain.com
MAILCHIMP_FROM_NAME=Slyde HQ

# ── OTP policy (optional — these are the defaults) ──────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
