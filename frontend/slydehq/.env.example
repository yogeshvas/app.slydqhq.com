# Base URL for XHR API requests (proxied to the backend in dev — see vite.config.ts).
VITE_API_BASE_URL=/api

# Absolute backend origin, used for full-page OAuth redirects.
VITE_BACKEND_URL=http://localhost:3000

# Google OAuth client ID — powers Google One Tap and the Google sign-in button.
# Same value as the backend's GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
